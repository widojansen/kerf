# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
kerf-*.tar

# Environment and secrets
.env
.env.*
!.env.example
*.secret
*.secrets
secrets/

# SQLite databases (dev/test — keep prod DB path in config, not here)
*.db*
*.sqlite
*.sqlite3

# VS Code
.vscode/
*.code-workspace

# IntelliJ / JetBrains (including IntelliJ IDEA, GoLand, RubyMine, etc.)
.idea/
*.iml
*.iws
*.ipr
out/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Elixir / Erlang
*.beam
*.plt
.elixir_ls/

# Logs
*.log
logs/

# Docker sandbox workspaces (per-group bind mounts)
/priv/workspaces/

# Telemetry fallback logs
/priv/telemetry_fallback/


# Memory/notes (workstation only)
.remember/
# Private working docs are kept in the outer folder, not in the repo
CLAUDE.md
EMAIL_TRIAGE_DIAGNOSTIC_SPEC.md
MODULE_MAP.md
TEST_CATALOG.md
AUTORESEARCH_PATTERN.md
REMOVE_STANDALONE_DASHBOARD_SPEC.md
RENAME_TO_KERF_SPEC.md
.claude-context/
.DS_Store
