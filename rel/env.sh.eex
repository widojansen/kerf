#!/bin/sh

# Release environment — evaluated on every release start.
# No distributed Erlang needed for single-node deployment.
export RELEASE_DISTRIBUTION=none

# Crash dumps written next to the release binary (not /tmp).
export ERL_CRASH_DUMP="${RELEASE_ROOT}/erl_crash.dump"

# IEx shell history for `bin/exclaw remote` sessions.
export ERL_AFLAGS="-kernel shell_history enabled"
